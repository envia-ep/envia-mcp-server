# Envia API token (required)
# Get your key from Desarrolladores → Acceso de API in your dashboard:
#   Sandbox:    https://shipping-test.envia.com/settings/developers
#   Production: https://shipping.envia.com/settings/developers
ENVIA_API_KEY=your_jwt_token_here

# Environment: "sandbox" (default) or "production"
ENVIA_ENVIRONMENT=sandbox
